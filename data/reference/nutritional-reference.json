  "definitions": {
    "rda": "Recommended Dietary Allowance — The nutrient intake level that meets the needs of 97–98% of healthy individuals",
    "ear": "Estimated Average Requirement — The nutrient intake level that meets the needs of 50% of the population",
    "ai": "Adequate Intake — The intake level established by observation or experiment when RDA data are unavailable",
    "ul": "Tolerable Upper Intake Level — The highest daily intake unlikely to cause adverse effects in almost all individuals",
    "dri": "Dietary Reference Intakes — A comprehensive reference system that includes RDA, EAR, AI, and UL"
  },

  "special_diets": {
    "dash": {
      "name": "DASH Diet (Hypertension)",
      "description": "Dietary Approaches to Stop Hypertension",
      "key_principles": [
        "Low sodium (<2300 mg/day; ideally <1500 mg)",
        "High potassium (3500–4700 mg/day)",
        "High calcium and magnesium",
        "Abundant vegetables and fruits, low-fat dairy, whole grains"
      ],
      "servings": {
