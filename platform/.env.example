# SynapseMD Platform Environment

APP_ENV=development
DEBUG=true
DATABASE_URL=sqlite+aiosqlite:///./synapsemd.db
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

OIDC_ISSUER=
OIDC_AUDIENCE=synapsemd-api

VAULT_URL=
FHIR_BASE_URL=http://localhost:8080/fhir
FHIR_LOCAL_STORE=./data/fhir

AUDIT_USE_MEMORY=true
LLM_DEFAULT_PROVIDER=mock
PRESIDIO_ENABLED=false
PHI_BLOCK_ON_FAILURE=true

RAG_VECTOR_STORE=memory
ENABLE_METRICS=true
ENABLE_TRACING=true
