# SynapseMD Platform Environment

APP_ENV=development
DEBUG=true
DATABASE_URL=sqlite+aiosqlite:///./synapsemd.db
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

OIDC_ISSUER=
OIDC_AUDIENCE=synapsemd-api

VAULT_URL=http://localhost:8200
VAULT_TOKEN=dev-root-token
VAULT_ENABLED=false

FHIR_BASE_URL=http://localhost:8080/fhir
FHIR_LOCAL_STORE=./data/fhir
FHIR_USE_HAPI=false

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_AUDIT_TOPIC=synapsemd.audit.events
AUDIT_USE_MEMORY=true
AUDIT_USE_KAFKA=false

LLM_DEFAULT_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_BAA_SIGNED=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_BAA_SIGNED=false
GOOGLE_API_KEY=
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com
GOOGLE_BAA_SIGNED=false

PRESIDIO_ENABLED=false
PHI_BLOCK_ON_FAILURE=true

RAG_VECTOR_STORE=memory
RAG_VECTOR_STORE_PATH=./data/rag
ORG_INTELLIGENCE_ENABLED=false

MCP_ENABLED=true
ENABLE_METRICS=true
ENABLE_TRACING=true

# MCP client token (set after login)
SYNAPSEMD_ACCESS_TOKEN=
